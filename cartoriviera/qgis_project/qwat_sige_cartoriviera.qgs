            <rule key="{deefd713-a3c8-4ce5-a7a5-e77174ab33f0}" label="pressurecontrol" filter="installation_type = 'pressurecontrol'">
              <rule key="{123cf1b6-ec41-4c8d-ae93-eae1cb518caf}" label="Chambre réducteur" symbol="2" filter=" &quot;fk_pressurecontrol_type&quot; =  2801 "/>
              <rule key="{0fbed74d-6f45-4d6a-a76b-14bf58918fca}" label="Chambre coupe pression" symbol="3" filter=" &quot;fk_pressurecontrol_type&quot; =  2802"/>
              <rule key="{e0d145e5-8c41-4094-9b53-8e9f8e6c320e}" label="Chambre de rassemblement" symbol="4" filter=" &quot;fk_pressurecontrol_type&quot; =  2803"/>
