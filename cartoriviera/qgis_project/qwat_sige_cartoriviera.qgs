              <rule key="{d9c0ef50-1a79-4f03-8ee2-c702e4197c4c}" label="Chambre" symbol="1" filter="installation_type = 'chamber' AND NOT (flow_meter = 'oui' or water_meter = 'oui' or manometer = 'oui')"/>
