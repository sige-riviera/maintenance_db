                      <Option name="active" type="bool" value="true"/>
                      <Option name="expression" type="QString" value="CASE WHEN &quot;diameter_nominal&quot; IS NOT NULL&#xd;&#xa;THEN min(1.0,max(.6,&#xd;&#xa;&#x9;abs(&#xd;&#xa;&#x9;&#x9;(to_real(COALESCE(&quot;diameter_nominal&quot;))-100) / 300 + 0.6&#xd;&#xa;&#x9;)&#xd;&#xa;))&#xd;&#xa;ELSE 0.6&#xd;&#xa;END"/>
