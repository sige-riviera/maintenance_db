          <rule key="{2c3f2183-dc95-44bf-a07e-fd3a221a1e0f}" filter="installation_type = 'chamber'" label="Chambre">
            <rule key="{99f834d5-87c3-4d1d-98d4-565eda330b74}" symbol="0" filter="flow_meter = 'oui' or water_meter = 'oui' or manometer = 'oui'" label="Chambre débitmètre"/>
